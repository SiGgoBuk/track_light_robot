<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ✅ 서버 통신을 위한 필수 권한 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Capstone"
        tools:targetApi="31">

        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".LoginActivity" />
        <activity android:name=".HomeActivity" />
        <activity android:name=".LightControlActivity" />
        <activity android:name=".ScheduleActivity" />
        <activity android:name=".RegisterActivity" />
        <activity android:name=".MyPageActivity"/>
        <activity android:name=".ColorPickerActivity" />
        <activity android:name=".ModeSelectActivity" />
        <activity android:name=".ControllerActivity" />
        <activity android:name=".LightModeSelectActivity" />
        <activity android:name=".AnalysisActivity" />
        <activity android:name=".ProductListActivity" />
        <activity android:name=".SettingActivity" />
        <activity android:name=".ControlHomeActivity" />
        <activity android:name=".VoiceCommandActivity" />

    </application>

</manifest>
