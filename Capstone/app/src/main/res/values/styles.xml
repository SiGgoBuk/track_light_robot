<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AnalysisCard">
        <item name="android:orientation">vertical</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">#F2F4F7</item>
    </style>

    <style name="AnalysisLabel">
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AnalysisValue">
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="VoiceTableHeader">
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">6dp</item>
    </style>

    <style name="VoiceTableCell">
        <item name="android:textColor">#C76E0E</item>
        <item name="android:textSize">15sp</item>
        <item name="android:padding">6dp</item>
    </style>

</resources>
